{
  "name": "nova-fleet",
  "version": "0.2.0",
  "private": true,
  "author": "Teknoist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Teknoist/Nova-Fleet.git"
  },
  "homepage": "https://github.com/Teknoist/Nova-Fleet",
  "description": "Modern multi-printer desktop manager for Nova3D printers",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/electron/main.js file:dist-electron/electron/preload.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "clean": "rimraf dist dist-electron",
    "build": "npm run clean && tsc -p tsconfig.electron.json && tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "android:sync": "npm run build:web && cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.7",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.1.0",
    "vitest": "^4.0.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.novafleet.desktop",
    "productName": "Nova Fleet",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Nova-Fleet-Setup-${version}.${ext}"
    }
  }
}
